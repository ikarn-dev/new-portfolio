{
  "redirects": [
    { "source": "/components/:path*", "destination": "/", "permanent": false },
    { "source": "/js/:path*", "destination": "/", "permanent": false },
    { "source": "/css/:path*", "destination": "/", "permanent": false }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/components/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ]
}
